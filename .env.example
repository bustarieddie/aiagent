APP_NAME="Klinik Bustari WhatsApp Agent"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://agent.klinikbustari.com
APP_TIMEZONE=Asia/Kuala_Lumpur

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=klinik_agent
DB_USERNAME=klinik_agent
DB_PASSWORD=

BROADCAST_CONNECTION=log
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=1440
QUEUE_CONNECTION=sync

# ─── Klinik Bustari custom ────────────────────────────────────────────────
ADMIN_PASSWORD=

# Comma-separated Malaysian phone numbers allowed to receive OTP + login.
# Any format accepted — 011-2233 4455, 60112233445, +60112233445.
ADMIN_ALLOWED_PHONES=+60112233445

PYTHON_BOT_URL=https://klinik-bustari-bot.on-forge.com
PYTHON_ADMIN_KEY=

APPOINTMENT_BOOKING_URL=https://klinikbustari.com/appointment.html

# ─── Telegram Monitor (mirror WhatsApp conversations to a staff group) ────
# 1. Create a bot with @BotFather → copy the token below.
# 2. Add the bot to your staff group, then get the group's chat id
#    (e.g. via @getidsbot). Group chat ids look like -1001234567890.
# 3. Enable "Telegram Monitor" on the Automation page.
TELEGRAM_BOT_TOKEN=
TELEGRAM_MONITOR_CHAT_ID=

# ─── WaSenderAPI (for OTP delivery via WhatsApp) ──────────────────────────
# Get key from wasenderapi.com dashboard. Bot already has one — reuse
# the same key here.
WASENDER_API_KEY=

# ─── Anthropic (for AI auto-classify service) ────────────────────────────
# Reuse the same key the Python bot uses. Leave blank to disable the
# "Auto-Classify Services" button on the Leads page.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ─── One-time Turso migration source ──────────────────────────────────────
# Set these ONLY for the initial `php artisan turso:pull` run.
# After migration is done, leave blank so no accidental re-fetch.
TURSO_URL=
TURSO_AUTH_TOKEN=
