APP_NAME="Klinik Bustari WhatsApp Agent"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://agent.klinikbustari.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=klinik_agent
DB_USERNAME=klinik_agent
DB_PASSWORD=

BROADCAST_CONNECTION=log
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=1440
QUEUE_CONNECTION=sync

# ─── Klinik Bustari custom ────────────────────────────────────────────────
ADMIN_PASSWORD=

# Comma-separated Malaysian phone numbers allowed to receive OTP + login.
# Any format accepted — 011-2233 4455, 60112233445, +60112233445.
ADMIN_ALLOWED_PHONES=+60112233445

PYTHON_BOT_URL=https://klinik-bustari-bot.on-forge.com
PYTHON_ADMIN_KEY=

APPOINTMENT_BOOKING_URL=https://klinikbustari.com/appointment.html

# ─── WaSenderAPI (for OTP delivery via WhatsApp) ──────────────────────────
# Get key from wasenderapi.com dashboard. Bot already has one — reuse
# the same key here.
WASENDER_API_KEY=

# ─── One-time Turso migration source ──────────────────────────────────────
# Set these ONLY for the initial `php artisan turso:pull` run.
# After migration is done, leave blank so no accidental re-fetch.
TURSO_URL=
TURSO_AUTH_TOKEN=
