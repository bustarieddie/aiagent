APP_NAME="Klinik Bustari WhatsApp Agent"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://agent.klinikbustari.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=klinik_agent
DB_USERNAME=klinik_agent
DB_PASSWORD=

BROADCAST_CONNECTION=log
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=1440
QUEUE_CONNECTION=sync

# ─── Klinik Bustari custom ────────────────────────────────────────────────
ADMIN_PASSWORD=

# Comma-separated emails allowed to receive OTP + login
ADMIN_ALLOWED_EMAILS=bustarieddie@gmail.com

PYTHON_BOT_URL=https://klinik-bustari-bot.on-forge.com
PYTHON_ADMIN_KEY=

APPOINTMENT_BOOKING_URL=https://klinikbustari.com/appointment.html

# ─── Mail (for OTP delivery) ──────────────────────────────────────────────
# Recommended: use Gmail SMTP with App Password, OR Resend/Postmark.
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@klinikbustari.com"
MAIL_FROM_NAME="Klinik Bustari Admin"

# ─── One-time Turso migration source ──────────────────────────────────────
# Set these ONLY for the initial `php artisan turso:pull` run.
# After migration is done, leave blank so no accidental re-fetch.
TURSO_URL=
TURSO_AUTH_TOKEN=
